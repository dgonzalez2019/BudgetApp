# Copy this file to .env and fill in what you need.

# ---------- Bank sync (Plaid) ----------
# Get free keys at https://dashboard.plaid.com/signup
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox = fake test banks | production = your real accounts
PLAID_ENV=sandbox

# ---------- Security (REQUIRED when hosting on the internet) ----------
# Setting a password turns on the login screen. Leave blank for local-only use.
APP_PASSWORD=
# Optional: random string that keeps you signed in across password changes.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# ---------- Hosting ----------
# PORT=3000
# Where the SQLite database lives (point at your host's persistent volume, e.g. /data)
# DATA_DIR=/data
